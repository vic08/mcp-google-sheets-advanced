{
  "name": "mcp-google-sheets-advanced",
  "version": "0.1.0",
  "description": "Advanced MCP server for Google Sheets — charts, pivot tables, formulas, formatting, and analytics",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-google-sheets-advanced": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-sheets",
    "spreadsheet",
    "ai",
    "claude",
    "charts",
    "pivot-tables",
    "analytics",
    "conditional-formatting",
    "data-validation",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vic08/mcp-google-sheets-advanced"
  },
  "homepage": "https://github.com/vic08/mcp-google-sheets-advanced#readme",
  "dependencies": {
    "@googleapis/sheets": "^13.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "googleapis": "^171.4.0",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.4",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
